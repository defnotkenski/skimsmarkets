XAI_API_KEY=xai-...
ANTHROPIC_API_KEY=sk-ant-...
# Optional: enables Unusual Whales flow-signal enrichment for the market_context specialist.
UNUSUAL_WHALES_API_KEY=
# Silence gRPC's "fork_posix / skipping fork handlers" info lines that xai_sdk
# triggers when specialists fan out. Set to NONE to silence everything, or leave
# unset to see the defaults.
GRPC_VERBOSITY=ERROR
