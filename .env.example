XAI_API_KEY=xai-...
ANTHROPIC_API_KEY=sk-ant-...
# Per-lens fetcher provider is hand-edited in `src/skimsmarkets/config.py`
# (`FETCHER_PROVIDER` constant; `gemini` by default, `grok` is the other
# option). No env var, no CLI flag. Only the chosen provider's API key is
# required at startup, so a Gemini-only run doesn't need XAI_API_KEY and
# vice versa.
GOOGLE_API_KEY=
# Optional: enables Unusual Whales flow-signal enrichment for the market_context specialist.
UNUSUAL_WHALES_API_KEY=
# Optional: enables third-party tennis player-stats enrichment (rankings, surface
# splits, recent form, head-to-head) for the statistics specialist. Used only on
# ATP/WTA singles head-to-heads — non-tennis events skip the call. The pipeline
# currently runs a stub provider that returns None for every match; once a
# concrete vendor adapter ships, this key flips it on. `--no-tennis-stats` on
# `skims rank` forces the stub even when the key is set.
TENNIS_STATS_API_KEY=
# Silence gRPC's "fork_posix / skipping fork handlers" info lines that xai_sdk
# triggers when specialists fan out. Set to NONE to silence everything, or leave
# unset to see the defaults.
GRPC_VERBOSITY=ERROR
