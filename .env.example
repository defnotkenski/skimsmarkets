XAI_API_KEY=xai-...
ANTHROPIC_API_KEY=sk-ant-...
# Per-lens fetcher provider. `grok` (default) uses xai_sdk + grok-4.20-multi-agent;
# `gemini` uses google-genai + gemini-3.1-pro single-pass. The --fetcher-provider
# CLI flag on `skims rank` overrides this. Only the chosen provider's API key is
# required at startup, so a Grok-only run doesn't need GOOGLE_API_KEY and vice versa.
# FETCHER_PROVIDER=grok
# Required when FETCHER_PROVIDER=gemini.
GOOGLE_API_KEY=
# Optional: enables Unusual Whales flow-signal enrichment for the market_context specialist.
UNUSUAL_WHALES_API_KEY=
# Silence gRPC's "fork_posix / skipping fork handlers" info lines that xai_sdk
# triggers when specialists fan out. Set to NONE to silence everything, or leave
# unset to see the defaults.
GRPC_VERBOSITY=ERROR
